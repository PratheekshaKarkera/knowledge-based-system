---
import Layout from '../../../layouts/Layout.astro';
import { api, type Article } from '../../../utils/api';

const { id } = Astro.params;

let article: Article | null = null;
try {
  article = await api.getArticleDetails(id as string); //article details
} catch (e) {
  return Astro.redirect('/admin');
}

if (!article) return Astro.redirect('/admin');
---

<Layout title="Edit Article">
  <div class="mb-8 flex items-center justify-between">
    <div>
      <a href="/admin" class="text-sm text-indigo-600 hover:text-indigo-800 font-medium flex items-center gap-1 mb-2 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        Back to Dashboard
      </a>
      <h1 class="text-3xl font-bold text-slate-900 tracking-tight flex items-center gap-3">
        Edit Article
        <span class={`text-xs px-2.5 py-1 rounded-full font-semibold border align-middle mt-1 ${
          article.published ? 'bg-emerald-50 text-emerald-700 border-emerald-200' : 'bg-amber-50 text-amber-700 border-amber-200'
        }`}>
          {article.published ? 'Published' : 'Draft'}
        </span>
      </h1>
      <p class="text-slate-500 mt-1">Make changes to the existing article content or categorisation.</p>
    </div>
  </div>

  <div class="bg-white border text-left border-slate-200 p-8 rounded-2xl shadow-sm max-w-3xl">
    <form id="edit-form" class="space-y-6">
      <input type="hidden" id="article-id" value={article.id}>

      <!-- Error Message Box -->
      <div id="error-box" class="hidden bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl shadow-sm text-sm">
      </div>
      
      <!-- Success Message Box -->
      <div id="success-box" class="hidden bg-emerald-50 border border-emerald-200 text-emerald-700 px-4 py-3 rounded-xl shadow-sm text-sm flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        Changes saved successfully! Redirecting...
      </div>

      <!-- Title Input -->
      <div>
        <label for="title" class="block text-sm font-semibold text-slate-900 mb-1.5">Article Title *</label>
        <div class="relative">
          <input 
            type="text" 
            id="title" 
            name="title" 
            value={article.title}
            required
            class="block w-full rounded-xl border-slate-200 px-4 py-3 bg-slate-50 border text-slate-900 focus:bg-white focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 transition-all outline-none"
          >
        </div>
      </div>

      <!-- Category Input -->
      <div>
        <label for="category" class="block text-sm font-semibold text-slate-900 mb-1.5">Category *</label>
        <div class="relative">
          <input 
            type="text" 
            id="category" 
            name="category" 
            value={article.category}
            required
            class="block w-full rounded-xl border-slate-200 px-4 py-3 bg-slate-50 border text-slate-900 focus:bg-white focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 transition-all outline-none"
          >
        </div>
      </div>

      <!-- Content Textarea -->
      <div>
        <label for="content" class="block text-sm font-semibold text-slate-900 mb-1.5 flex justify-between">
          <span>Article Content *</span>
          <span id="char-count" class="text-slate-400 font-normal text-xs">{article.content.length} characters (min 50)</span>
        </label>
        <textarea 
          id="content" 
          name="content" 
          rows="12" 
          required
          minlength="50"
          class="block w-full rounded-xl border-slate-200 px-4 py-3 bg-slate-50 border text-slate-900 focus:bg-white focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 transition-all outline-none resize-y"
        >{article.content}</textarea>
      </div>

      <!-- Submit Button -->
      <div class="pt-2 border-t border-slate-100 flex justify-end gap-3 mt-8">
        <a href="/admin" class="px-5 py-2.5 rounded-xl font-medium text-slate-600 bg-white border border-slate-200 hover:bg-slate-50 transition-colors cursor-pointer">
          Cancel
        </a>
        <button 
          type="submit" 
          id="submit-btn"
          class="inline-flex justify-center items-center gap-2 px-6 py-2.5 bg-indigo-600 text-white rounded-xl font-medium shadow-sm hover:shadow-md hover:bg-indigo-700 transition-all focus:ring-4 focus:ring-indigo-500/20 outline-none"
        >
          <span>Update Document</span>
        </button>
      </div>
    </form>
  </div>
</Layout>

<script>
  import { api } from '../../../utils/api';

  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('edit-form') as HTMLFormElement;
    const errorBox = document.getElementById('error-box');
    const successBox = document.getElementById('success-box');
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const articleIdInput = document.getElementById('article-id') as HTMLInputElement;
    const contentTextarea = document.getElementById('content') as HTMLTextAreaElement;
    const charCount = document.getElementById('char-count');

    // Live character count validator
    if (contentTextarea && charCount) {
      const updateCharCount = () => {
        const len = contentTextarea.value.length;
        charCount.textContent = `${len} characters (min 50)`;
        if (len >= 50) {
          charCount.classList.add('text-emerald-500');
          charCount.classList.remove('text-red-500', 'text-slate-400');
        } else {
          charCount.classList.add('text-red-500');
          charCount.classList.remove('text-emerald-500', 'text-slate-400');
        }
      };
      
      // Initial style setup
      updateCharCount();
      
      contentTextarea.addEventListener('input', updateCharCount);
    }

    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const id = articleIdInput.value;
        
        // Reset States
        if (errorBox) {
          errorBox.classList.add('hidden');
          errorBox.textContent = '';
        }
        if (successBox) successBox.classList.add('hidden');

        // Form Data
        const formData = new FormData(form);
        const title = formData.get('title') as string;
        const category = formData.get('category') as string;
        const content = formData.get('content') as string;

        submitBtn.disabled = true;
        const originalText = submitBtn.innerHTML;
        submitBtn.innerHTML = '<span class="flex items-center gap-2">Updating...</span>';
    
       //update artical 
        try {
          await api.updateArticle(id, { title, category, content });
          
          // Trigger the toast on the next page load
          sessionStorage.setItem('toastMessage', `"${title}" saved successfully!`);
          
          if (successBox) successBox.classList.remove('hidden');
          
          setTimeout(() => {
            window.location.href = '/admin';
          }, 1000);
        } catch (error: any) {
          if (errorBox) {
            errorBox.classList.remove('hidden');
            errorBox.textContent = error.message.replace('invalid request: ', '');
          }
          submitBtn.disabled = false;
          submitBtn.innerHTML = originalText;
        }
      });
    }
  });
</script>
