---
import Layout from '../../layouts/Layout.astro';
import { api, type Article } from '../../utils/api';

let articles: Article[] = [];
let stats = { total: 0, published: 0, drafts: 0 };
let error = null;

try {
  articles = await api.getAllArticles();
  stats = await api.getStats();   //stats
} catch (e) {
  error = 'Failed to load admin dashboard data.';
}
---

<Layout title="Admin Dashboard">
  <div class="mb-8 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
    <div>
      <h1 class="text-3xl font-bold text-slate-900 tracking-tight">Admin Dashboard</h1>
      <p class="text-slate-500 mt-1">Manage all your knowledge base articles here.</p>
    </div>
    <a href="/admin/create" class="inline-flex items-center gap-2 px-5 py-2.5 bg-indigo-600 text-white rounded-xl font-medium shadow-sm hover:shadow-md hover:bg-indigo-700 transition-all">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
      New Article
    </a>
  </div>

  {error && (
    <div class="bg-red-50 text-red-700 p-4 rounded-xl border border-red-200 mb-8 flex items-center gap-3">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
      {error}
    </div>
  )}

  <!-- Stats Cards -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-8">
    <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm relative overflow-hidden group">
      <div class="absolute top-0 right-0 w-24 h-24 bg-slate-50 rounded-bl-full -z-10 group-hover:scale-110 transition-transform"></div>
      <div class="text-slate-500 font-medium text-sm mb-1 uppercase tracking-wider">Total Articles</div>
      <div class="text-4xl font-bold text-slate-900">{stats.total}</div>
    </div>
    <div class="bg-white p-6 rounded-2xl border border-emerald-100 shadow-sm relative overflow-hidden group">
      <div class="absolute top-0 right-0 w-24 h-24 bg-emerald-50 rounded-bl-full -z-10 group-hover:scale-110 transition-transform"></div>
      <div class="text-emerald-600 font-medium text-sm mb-1 uppercase tracking-wider">Published</div>
      <div id="stat-published" class="text-4xl font-bold text-emerald-700">{stats.published}</div>
    </div>
    <div class="bg-white p-6 rounded-2xl border border-amber-100 shadow-sm relative overflow-hidden group">
      <div class="absolute top-0 right-0 w-24 h-24 bg-amber-50 rounded-bl-full -z-10 group-hover:scale-110 transition-transform"></div>
      <div class="text-amber-600 font-medium text-sm mb-1 uppercase tracking-wider">Drafts</div>
      <div id="stat-drafts" class="text-4xl font-bold text-amber-700">{stats.drafts}</div>
    </div>
  </div>

  <!-- Articles List -->
  <div class="bg-white border border-slate-200 rounded-2xl shadow-sm overflow-hidden">
    <div class="px-6 py-4 border-b border-slate-200 bg-slate-50">
      <h2 class="font-semibold text-slate-800 tracking-tight">All Articles</h2>
    </div>
    
    {articles.length === 0 ? (
      <div class="p-12 text-center text-slate-500">
        No articles found in the database. 
      </div>
    ) : (
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="bg-white text-slate-500 text-xs uppercase tracking-wider border-b border-slate-200">
              <th class="px-6 py-3 font-medium">Title & Category</th>
              <th class="px-6 py-3 font-medium">Status</th>
              <th class="px-6 py-3 font-medium">Date</th>
              <th class="px-6 py-3 font-medium text-right">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            {articles.map((article) => (
              <tr class="hover:bg-slate-50 transition-colors group">
                <td class="px-6 py-4">
                  <div class="font-medium text-slate-900 mb-0.5 max-w-xs md:max-w-md truncate" title={article.title}>
                    {article.title}
                  </div>
                  <div class="text-xs text-slate-500 font-medium">{article.category}</div>
                </td>
                <td class="px-6 py-4">
                  <button 
                    class={`publish-btn px-2.5 py-1 rounded-full text-xs font-semibold border transition-colors ${
                      article.published 
                        ? 'bg-emerald-50 text-emerald-700 border-emerald-200 hover:bg-emerald-100' 
                        : 'bg-slate-100 text-slate-600 border-slate-200 hover:bg-slate-200'
                    }`}
                    data-id={article.id}
                    data-published={article.published ? 'true' : 'false'}
                  >
                    {article.published ? 'Published' : 'Draft'}
                  </button>
                </td>
                <td class="px-6 py-4 text-sm text-slate-500">
                   {new Date(article.createdAt).toLocaleDateString()}
                </td>
                <td class="px-6 py-4 text-right">
                  <div class="flex items-center justify-end gap-2">
                    <!-- View Button -->
                    <div class="relative group/btn">
                      <a href={`/article/${article.slug}`} target="_blank" class="p-1.5 inline-flex text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded transition-colors" aria-label="View">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
                      </a>
                      <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 px-2 py-1 bg-slate-800 text-white text-xs font-medium rounded opacity-0 invisible group-hover/btn:opacity-100 group-hover/btn:visible transition-all whitespace-nowrap z-50">
                        View
                        <svg aria-hidden="true" width="16" height="6" viewBox="0 0 16 6" class="absolute top-full text-slate-800 left-1/2 -translate-x-1/2"><path fill="currentColor" fill-rule="evenodd" clip-rule="evenodd" d="M15 0H1V1.00366V1.00366V1.00371H1.01672C2.72058 1.0147 4.24225 2.74704 5.42685 4.72928C6.42941 6.40691 9.57154 6.4069 10.5741 4.72926C11.7587 2.74703 13.2803 1.0147 14.9841 1.00371H15V0Z"></path></svg>
                      </div>
                    </div>
                    
                    <!-- Edit Button -->
                    <div class="relative group/btn">
                      <a href={`/admin/edit/${article.id}`} class="p-1.5 inline-flex text-slate-400 hover:text-blue-600 hover:bg-blue-50 rounded transition-colors" aria-label="Edit">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
                      </a>
                      <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 px-2 py-1 bg-slate-800 text-white text-xs font-medium rounded opacity-0 invisible group-hover/btn:opacity-100 group-hover/btn:visible transition-all whitespace-nowrap z-50">
                        Edit
                        <svg aria-hidden="true" width="16" height="6" viewBox="0 0 16 6" class="absolute top-full text-slate-800 left-1/2 -translate-x-1/2"><path fill="currentColor" fill-rule="evenodd" clip-rule="evenodd" d="M15 0H1V1.00366V1.00366V1.00371H1.01672C2.72058 1.0147 4.24225 2.74704 5.42685 4.72928C6.42941 6.40691 9.57154 6.4069 10.5741 4.72926C11.7587 2.74703 13.2803 1.0147 14.9841 1.00371H15V0Z"></path></svg>
                      </div>
                    </div>

                    <!-- Delete Button -->
                    <div class="relative group/btn">
                      <button class="delete-btn p-1.5 inline-flex text-slate-400 hover:text-red-600 hover:bg-red-50 rounded transition-colors" aria-label="Delete" data-id={article.id} data-title={article.title}>
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                      </button>
                      <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 px-2 py-1 bg-slate-800 text-white text-xs font-medium rounded opacity-0 invisible group-hover/btn:opacity-100 group-hover/btn:visible transition-all whitespace-nowrap z-50">
                        Delete
                        <svg aria-hidden="true" width="16" height="6" viewBox="0 0 16 6" class="absolute top-full text-slate-800 left-1/2 -translate-x-1/2"><path fill="currentColor" fill-rule="evenodd" clip-rule="evenodd" d="M15 0H1V1.00366V1.00366V1.00371H1.01672C2.72058 1.0147 4.24225 2.74704 5.42685 4.72928C6.42941 6.40691 9.57154 6.4069 10.5741 4.72926C11.7587 2.74703 13.2803 1.0147 14.9841 1.00371H15V0Z"></path></svg>
                      </div>
                    </div>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </div>

  <!-- Custom Delete Confirmation Modal -->
  <div id="delete-modal" class="fixed inset-0 z-50 flex items-center justify-center hidden">
    <!-- Backdrop -->
    <div class="absolute inset-0 bg-slate-900/40 backdrop-blur-sm transition-opacity" id="delete-modal-backdrop"></div>
    
    <!-- Modal Content -->
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md mx-4 relative z-10 p-6 transform transition-all scale-95 opacity-0" id="delete-modal-content">
      <div class="flex items-start gap-4 mb-4">
        <div class="w-12 h-12 rounded-full bg-red-100 flex items-center justify-center flex-shrink-0 mt-1">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-red-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        </div>
        <div>
          <h3 class="text-xl font-bold text-slate-900">Delete Article</h3>
          <p class="text-slate-500 text-sm mt-1 mb-3">Are you sure you want to permanently delete this article? This action cannot be undone.</p>
          <div class="bg-slate-50 p-3 rounded-xl border border-slate-200">
            <p class="text-slate-800 text-sm font-semibold line-clamp-2" id="delete-modal-title"></p>
          </div>
        </div>
      </div>

      <div class="flex justify-end gap-3 mt-8">
        <button id="delete-modal-cancel" class="px-5 py-2.5 bg-white border border-slate-200 text-slate-700 rounded-xl hover:bg-slate-50 font-medium transition-colors">
          Cancel
        </button>
        <button id="delete-modal-confirm" class="px-5 py-2.5 bg-red-600 text-white rounded-xl hover:bg-red-700 font-medium transition-colors flex items-center justify-center gap-2 min-w-[100px] shadow-sm">
          Delete
        </button>
      </div>
    </div>
  </div>

  <!-- Success Toast -->
  <div id="toast" class="fixed top-8 left-1/2 -translate-x-1/2 bg-slate-900 border border-slate-700 text-white px-5 py-3.5 rounded-xl shadow-2xl flex items-center gap-3 transform transition-all duration-300 -translate-y-10 opacity-0 z-[60]">
    <div class="w-6 h-6 rounded-full bg-emerald-500/20 flex items-center justify-center flex-shrink-0">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-emerald-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
    </div>
    <span id="toast-message" class="text-sm font-medium pr-2"></span>
  </div>
</Layout>

<script>
  import { api } from '../../utils/api';

  document.addEventListener('DOMContentLoaded', () => {
    // Reusable Toast Function
    const toast = document.getElementById('toast');
    const toastMessage = document.getElementById('toast-message');

    const showToast = (message: string) => {
      if (!toast || !toastMessage) return;
      toastMessage.textContent = message;
      toast.classList.remove('-translate-y-10', 'opacity-0');
      
      setTimeout(() => {
        toast.classList.add('-translate-y-10', 'opacity-0');
      }, 3000);
    };

    // Handle Publish Toggle
    const publishBtns = document.querySelectorAll('.publish-btn');
    publishBtns.forEach(btn => {
      btn.addEventListener('click', async (e) => {
        const target = e.currentTarget as HTMLButtonElement;
        const id = target.getAttribute('data-id');
        const currentlyPublished = target.getAttribute('data-published') === 'true';
        const newStatus = !currentlyPublished;
        
        // Optimistic UI update
        target.disabled = true;
        target.textContent = 'Updating...';
        
        try {
          await api.togglePublish(id!, newStatus);
          
          // Smoothly update button without reloading
          target.setAttribute('data-published', newStatus ? 'true' : 'false');
          target.textContent = newStatus ? 'Published' : 'Draft';
          target.className = `publish-btn px-2.5 py-1 rounded-full text-xs font-semibold border transition-colors ${
            newStatus 
              ? 'bg-emerald-50 text-emerald-700 border-emerald-200 hover:bg-emerald-100' 
              : 'bg-slate-100 text-slate-600 border-slate-200 hover:bg-slate-200'
          }`;
          target.disabled = false;
          
          // Smoothly update Statistics
          const pubStat = document.getElementById('stat-published');
          const draftStat = document.getElementById('stat-drafts');
          if (pubStat && draftStat) {
            let pCount = parseInt(pubStat.textContent || '0');
            let dCount = parseInt(draftStat.textContent || '0');
            pubStat.textContent = (newStatus ? pCount + 1 : pCount - 1).toString();
            draftStat.textContent = (newStatus ? dCount - 1 : dCount + 1).toString();
          }
          
          // Show Toast Notification
          showToast(`Article successfully ${newStatus ? 'published' : 'moved to drafts'}`);
          
        } catch (error) {
          alert('Failed to update publish status');
          target.textContent = currentlyPublished ? 'Published' : 'Draft';
          target.disabled = false;
        }
      });
    });

    // Handle Delete Modal Javascript
    const deleteModal = document.getElementById('delete-modal');
    const deleteModalBackdrop = document.getElementById('delete-modal-backdrop');
    const deleteModalContent = document.getElementById('delete-modal-content');
    const deleteModalTitle = document.getElementById('delete-modal-title');
    const deleteModalCancel = document.getElementById('delete-modal-cancel');
    const deleteModalConfirm = document.getElementById('delete-modal-confirm') as HTMLButtonElement;
    
    let articleToDeleteId: string | null = null;

    const hideModal = () => {
      deleteModalContent?.classList.replace('scale-100', 'scale-95');
      deleteModalContent?.classList.replace('opacity-100', 'opacity-0');
      setTimeout(() => {
        deleteModal?.classList.add('hidden');
        articleToDeleteId = null;
      }, 200);
    };

    const showModal = (id: string, title: string) => {
      articleToDeleteId = id;
      if (deleteModalTitle) deleteModalTitle.textContent = `"${title}"`;
      deleteModal?.classList.remove('hidden');
      
      // Small delay to allow display block to apply before animating opacity
      setTimeout(() => {
        deleteModalContent?.classList.replace('scale-95', 'scale-100');
        deleteModalContent?.classList.replace('opacity-0', 'opacity-100');
      }, 10);
    };

    deleteModalCancel?.addEventListener('click', hideModal);
    deleteModalBackdrop?.addEventListener('click', hideModal);

    deleteModalConfirm?.addEventListener('click', async () => {
      if (!articleToDeleteId) return;
      
      deleteModalConfirm.disabled = true;
      deleteModalConfirm.innerHTML = '<svg class="animate-spin -ml-1 mr-2 h-4 w-4 text-white inline flex-shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Deleting...';
      
      try {
        await api.deleteArticle(articleToDeleteId);
        sessionStorage.setItem('toastMessage', 'Article deleted successfully!');
        window.location.reload();
      } catch (error) {
        alert('Failed to delete article');
        deleteModalConfirm.disabled = false;
        deleteModalConfirm.innerHTML = 'Delete';
        hideModal();
      }
    });

    const deleteBtns = document.querySelectorAll('.delete-btn');
    deleteBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        const target = e.currentTarget as HTMLButtonElement;
        const id = target.getAttribute('data-id');
        const title = target.getAttribute('data-title');
        
        if (id && title) {
          showModal(id, title);
        }
      });
    });

    // Handle pending toast (from redirects)
    const pendingToast = sessionStorage.getItem('toastMessage');
    if (pendingToast) {
      sessionStorage.removeItem('toastMessage');
      setTimeout(() => showToast(pendingToast), 100);
    }
  });
</script>
