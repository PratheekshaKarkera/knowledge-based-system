---
import Layout from "../layouts/Layout.astro";
import { api, type Article } from "../utils/api";

// Fetch all published articles to search against natively on the client
// A more robust backend search endpoint could be implemented for production,
// but client side is extremely fast for small to medium knowledge bases!
let articles: Article[] = [];
let error: string | null = null;

try {
  articles = await api.getPublishedArticles();
} catch (e) {
  error = "Failed to load articles for search.";
}
---

<Layout title="Search Articles">
  <div class="max-w-3xl mx-auto mt-4 mb-10 w-full animate-fade-in">
    <div class="text-center mb-8">
      <h1
        class="text-3xl sm:text-4xl font-extrabold tracking-tight text-slate-900 mb-4"
      >
        What are you looking for?
      </h1>
      <p class="text-slate-600 max-w-xl mx-auto">
        Search through our knowledge base of tutorials, guides, and
        documentation.
      </p>
    </div>

    <!-- Search Input Area -->
    <div
      class="relative bg-white border outline-none focus-within:ring-4 ring-indigo-500/10 focus-within:border-indigo-400 border-slate-200 shadow-sm rounded-2xl flex items-center p-2 mb-8 transition-all group overflow-hidden"
    >
      <!-- Hidden serialized articles for client JS to read -->
      <script
        type="application/json"
        is:inline
        id="article-data"
        set:html={JSON.stringify(articles)}
      />

      <div
        class="p-3 text-slate-400 group-focus-within:text-indigo-600 transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-6 h-6"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"
          ></path></svg
        >
      </div>
      <input
        type="search"
        id="search-input"
        placeholder="Search for 'cloudflare worker', 'api deployment'..."
        class="w-full bg-transparent text-slate-900 placeholder:text-slate-400 focus:outline-none text-lg py-2 truncate"
        autocomplete="off"
        autofocus
      />
      <div
        id="search-count"
        class="px-4 text-xs font-semibold text-slate-400 hidden sm:block whitespace-nowrap"
      >
        {articles.length} total
      </div>
    </div>

    {
      error && (
        <div class="bg-red-50 text-red-700 p-4 rounded-xl border border-red-200 text-center shadow-sm mb-8">
          {error}
        </div>
      )
    }

    <!-- Search Results Container -->
    <div id="search-results-container" class="space-y-4">
      <!-- Unsearched / Default View -->
      <div id="default-state" class="text-center py-16">
        <div
          class="inline-flex w-16 h-16 bg-slate-100 rounded-full items-center justify-center text-slate-400 mb-4"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-8 h-8"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M12 2v20"></path><path
              d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg
          >
        </div>
        <h3 class="text-lg font-medium text-slate-700">
          Type to begin searching
        </h3>
        <p class="text-slate-500 mt-1">
          Start typing keywords to find helpful articles.
        </p>
      </div>

      <!-- No Results State -->
      <div
        id="no-results"
        class="hidden text-center py-16 border border-slate-200 border-dashed rounded-2xl bg-slate-50"
      >
        <div
          class="inline-flex w-12 h-12 bg-slate-200 rounded-full items-center justify-center text-slate-500 mb-3"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-6 h-6"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"
            ></path><path d="m9 9 4 4"></path><path d="m13 9-4 4"></path></svg
          >
        </div>
        <h3 class="text-lg text-slate-800 font-medium">No matches found</h3>
        <p class="text-slate-500 mt-1 max-w-sm mx-auto text-sm">
          We couldn't find any articles matching your search query. Try
          different keywords or check out categories on the homepage.
        </p>
      </div>

      <!-- Results Grid (Populated dynamically) -->
      <div id="results-grid" class="flex flex-col gap-4"></div>
    </div>
  </div>
</Layout>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const input = document.getElementById("search-input") as HTMLInputElement;
    const defaultState = document.getElementById("default-state");
    const noResults = document.getElementById("no-results");
    const resultsGrid = document.getElementById("results-grid");
    const countDisplay = document.getElementById("search-count");
    const rawData = document.getElementById("article-data")?.textContent;

    let articles: any[] = [];
    try {
      if (rawData) articles = JSON.parse(rawData);
    } catch (e) {
      console.error("Failed to parse articles for client search");
    }

    // Highlighting helper function
    function highlight(text: string, query: string): string {
      if (!query.trim()) return text;
      const regex = new RegExp(
        `(${query.replace(/[.*+?^${}()|[\]\\]/g, "\\$&")})`,
        "gi",
      );
      return text.replace(
        regex,
        '<mark class="bg-indigo-100 text-indigo-900 rounded-[2px] px-0.5 font-medium">$1</mark>',
      );
    }

    if (input) {
      input.addEventListener("input", (e) => {
        const query = (e.target as HTMLInputElement).value.toLowerCase().trim();

        if (!query) {
          if (defaultState) defaultState.classList.remove("hidden");
          if (noResults) noResults.classList.add("hidden");
          if (resultsGrid) resultsGrid.innerHTML = "";
          if (countDisplay)
            countDisplay.textContent = `${articles.length} total`;
          return;
        }

        if (defaultState) defaultState.classList.add("hidden");

        // Very basic client-side search across Title, Category, and Content
        const matchedArticles = articles.filter((article) => {
          return (
            article.title.toLowerCase().includes(query) ||
            article.category.toLowerCase().includes(query) ||
            article.content.toLowerCase().includes(query)
          );
        });

        if (countDisplay) {
          countDisplay.textContent = `${matchedArticles.length} result(s)`;
        }

        if (matchedArticles.length === 0) {
          if (noResults) noResults.classList.remove("hidden");
          if (resultsGrid) resultsGrid.innerHTML = "";
        } else {
          if (noResults) noResults.classList.add("hidden");
          if (resultsGrid) {
            resultsGrid.innerHTML = matchedArticles
              .map(
                (article) => `
              <a href="/article/${article.slug}" class="block group">
                <article class="bg-white border border-slate-200 rounded-xl p-5 shadow-sm hover:shadow-md hover:border-indigo-300 transition-all">
                  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-2">
                    <h3 class="text-lg font-bold text-slate-900 group-hover:text-indigo-600 transition-colors">
                      ${highlight(article.title, query)}
                    </h3>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-slate-100 text-slate-600 w-fit">
                      ${highlight(article.category, query)}
                    </span>
                  </div>
                  <p class="text-slate-600 text-sm line-clamp-2">
                    ${highlight(article.content, query)}
                  </p>
                </article>
              </a>
            `,
              )
              .join("");
          }
        }
      });
    }
  });
</script>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-in {
    animation: fadeIn 0.4s ease-out forwards;
  }
</style>
